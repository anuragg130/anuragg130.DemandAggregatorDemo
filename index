function mkey(){return metric==="current"?"c":metric==="m6"?"a":"b";}
function heatColor(t){const stops=[[0,[255,247,194]],[0.5,[255,212,0]],[1,[156,122,0]]];let i=0;while(i<stops.length-1&&t>stops[i+1][0])i++;
  const[a,ca]=stops[i],[b,cb]=stops[Math.min(i+1,stops.length-1)];const f=b===a?0:(t-a)/(b-a);
  const c=ca.map((v,j)=>Math.round(v+(cb[j]-v)*f));return `rgb(${c[0]},${c[1]},${c[2]})`;}

