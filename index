<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Skilled Manpower Demand Aggregation — FMCG Value Chain</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  :root{--ey-yellow:#FFE600;--charcoal:#2E2E38;--charcoal-2:#3a3a46;--ink:#1b1b21;--muted:#71717f;
    --line:#e4e4ea;--bg:#f2f2f5;--white:#fff;--teal:#2DA89C;--red:#d64545;
    --shadow:0 1px 2px rgba(46,46,56,.06),0 8px 24px rgba(46,46,56,.06)}
  *{box-sizing:border-box} html,body{margin:0;padding:0}
  body{font-family:'Manrope',sans-serif;background:var(--bg);color:var(--ink);-webkit-font-smoothing:antialiased;line-height:1.5}
  h1,h2,h3,h4{font-family:'Archivo',sans-serif;margin:0;letter-spacing:-.01em}
  header{background:var(--charcoal);color:#fff;position:relative;overflow:hidden}
  header::after{content:"";position:absolute;right:-60px;top:0;bottom:0;width:220px;
    background:linear-gradient(105deg,transparent 0 48%,var(--ey-yellow) 48% 56%,transparent 56%);opacity:.9}
  .head-inner{max-width:1280px;margin:0 auto;padding:22px 32px 16px;position:relative;z-index:2}
  .brandrow{display:flex;align-items:center;gap:16px}
  .ey-mark{font-family:'Archivo';font-weight:800;font-size:26px;color:#fff;display:inline-flex;align-items:center;gap:8px}
  .ey-mark .beam{width:26px;height:26px;display:inline-block;
    background:linear-gradient(135deg,var(--ey-yellow) 0 60%,#caa500 60% 100%);clip-path:polygon(0 100%,100% 0,100% 38%,38% 100%)}
  .head-titles{flex:1;min-width:0}.head-titles h1{font-size:22px;font-weight:700;color:#fff}
  .head-titles p{margin:2px 0 0;color:#c7c7d2;font-size:13.5px}
  .tag{background:var(--ey-yellow);color:var(--charcoal);font-family:'Archivo';font-weight:700;font-size:11px;letter-spacing:.06em;text-transform:uppercase;padding:6px 11px;border-radius:3px}
  .tabbar{max-width:1280px;margin:0 auto;padding:0 32px;display:flex;gap:4px}
  .tab{background:none;border:none;cursor:pointer;font-family:'Archivo';font-weight:600;font-size:14px;color:var(--muted);padding:14px 18px;border-bottom:3px solid transparent;margin-bottom:-1px}
  .tab.active{color:var(--charcoal);border-bottom-color:var(--ey-yellow)}
  .tab .badge{background:var(--charcoal);color:#fff;font-size:11px;border-radius:20px;padding:1px 8px;margin-left:6px;font-family:'Manrope';font-weight:700}
  .wrap{max-width:1280px;margin:0 auto;padding:26px 32px 80px}
  .view{display:none}.view.show{display:block;animation:fade .3s ease}
  @keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  .card{background:var(--white);border:1px solid var(--line);border-radius:8px;box-shadow:var(--shadow)}
  .card-h{padding:16px 22px;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:12px;flex-wrap:wrap}
  .card-h h2{font-size:16px;font-weight:700}.card-h .sub{color:var(--muted);font-size:12.5px;font-weight:500}
  .step-no{font-family:'Archivo';font-weight:800;font-size:12px;background:var(--charcoal);color:#fff;width:24px;height:24px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex:0 0 auto}
  .card-b{padding:22px}.mb{margin-bottom:20px}
  .grid{display:grid;gap:16px}.g3{grid-template-columns:repeat(3,1fr)}
  label{display:block;font-size:12px;font-weight:700;color:var(--charcoal);margin-bottom:6px}label .req{color:var(--red)}
  input,select{width:100%;font-family:'Manrope';font-size:14px;padding:10px 12px;border:1px solid var(--line);border-radius:6px;background:#fafafb;color:var(--ink);transition:.15s}
  input:focus,select:focus{outline:none;border-color:var(--charcoal);background:#fff;box-shadow:0 0 0 3px rgba(255,230,0,.35)}
  input::placeholder{color:#aaa}
  .vc-pick{display:grid;grid-template-columns:repeat(auto-fill,minmax(215px,1fr));gap:12px}
  .vc-btn{cursor:pointer;border:1.5px solid var(--line);background:#fafafb;border-radius:8px;padding:13px 15px;text-align:left;transition:.15s;font-family:'Manrope'}
  .vc-btn:hover{border-color:#bdbdc8}.vc-btn.sel{border-color:var(--charcoal);background:#fff;box-shadow:0 0 0 3px rgba(255,230,0,.4)}
  .vc-btn .num{font-family:'Archivo';font-weight:800;font-size:12px;color:#fff;background:var(--charcoal);width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;margin-bottom:7px}
  .vc-btn.sel .num{background:var(--ey-yellow);color:var(--charcoal)}
  .vc-btn .nm{font-family:'Archivo';font-weight:700;font-size:14px;display:block;line-height:1.25}
  .vc-btn .ct{font-size:11px;color:var(--muted);margin-top:3px;display:block}
  .lines{margin-top:4px;overflow-x:auto}.lines table{width:100%;border-collapse:collapse;min-width:820px}
  .lines th{font-family:'Archivo';font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted);text-align:left;padding:8px 9px;border-bottom:2px solid var(--line);white-space:nowrap}
  .lines td{padding:7px 9px;border-bottom:1px solid var(--line);vertical-align:middle}
  .lines input,.lines select{padding:8px 9px;font-size:13px}.lines input[type=number]{max-width:90px}
  .ssother{display:flex;gap:6px;align-items:center}
  .revert,.revert-d{flex:0 0 auto;border:1px solid var(--line);background:#fff;border-radius:5px;width:30px;height:34px;cursor:pointer;font-size:14px;color:var(--muted)}
  .revert:hover,.revert-d:hover{border-color:var(--charcoal);color:var(--charcoal)}
  .rm{border:none;background:none;color:var(--red);font-size:20px;line-height:1;cursor:pointer;padding:2px 8px;border-radius:5px}.rm:hover{background:#fde8e8}
  .empty-d{padding:30px;text-align:center;color:var(--muted);font-size:13.5px;border:1.5px dashed var(--line);border-radius:8px}
  .actions{display:flex;gap:12px;align-items:center;margin-top:18px;flex-wrap:wrap}
  .btn{font-family:'Archivo';font-weight:700;font-size:14px;border:none;border-radius:6px;cursor:pointer;padding:11px 20px;transition:.15s;display:inline-flex;align-items:center;gap:8px}
  .btn-primary{background:var(--ey-yellow);color:var(--charcoal)}.btn-primary:hover{background:#ffec40;box-shadow:0 6px 16px rgba(255,230,0,.4)}
  .btn-ghost{background:#fff;color:var(--charcoal);border:1px solid var(--line)}.btn-ghost:hover{border-color:var(--charcoal)}
  .btn-dark{background:var(--charcoal);color:#fff}.btn-dark:hover{background:#1f1f27}
  .btn-sm{padding:8px 14px;font-size:12.5px}.btn:disabled{opacity:.5;cursor:not-allowed}
  .hint{color:var(--muted);font-size:12.5px}
  .notice{background:#fffbe6;border:1px solid #f3e08a;border-radius:6px;padding:10px 14px;font-size:12.5px;color:#6b5d00;margin-bottom:18px}
  .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--charcoal);color:#fff;padding:14px 20px;border-radius:8px;font-weight:600;font-size:14px;box-shadow:0 12px 40px rgba(0,0,0,.3);opacity:0;pointer-events:none;transition:.3s;z-index:50;border-left:4px solid var(--ey-yellow)}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .toolbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px;flex-wrap:wrap;gap:12px}.toolbar h2{font-size:18px}
  .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin-bottom:16px}
  .kpi{background:#fff;border:1px solid var(--line);border-radius:8px;padding:16px 18px;box-shadow:var(--shadow);position:relative;overflow:hidden}
  .kpi::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--ey-yellow)}
  .kpi .lab{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);font-weight:700}
  .kpi .val{font-family:'Archivo';font-weight:800;font-size:28px;line-height:1.1;margin-top:5px}
  .kpi .sub{font-size:11.5px;color:var(--muted);margin-top:2px}
  .chips{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px}
  .chip{background:#fff;border:1px solid var(--line);border-radius:30px;padding:6px 14px;font-size:12.5px;font-weight:600;color:var(--charcoal)}.chip b{font-family:'Archivo';margin-right:3px}
  .metricbar{display:flex;align-items:center;gap:14px;margin-bottom:18px;flex-wrap:wrap}
  .metric-toggle{display:inline-flex;border:1px solid var(--line);border-radius:8px;overflow:hidden;background:#fff}
  .metric-toggle button{border:none;background:#fff;padding:9px 16px;font-family:'Archivo';font-weight:600;font-size:13px;cursor:pointer;color:var(--muted)}
  .metric-toggle button.on{background:var(--charcoal);color:#fff}
  .filtbar{display:flex;gap:14px;flex-wrap:wrap;align-items:end}
  .fitem{display:flex;flex-direction:column;min-width:175px;flex:1}.fitem label{margin-bottom:5px}.fitem select{background:#fff}
  .gbar{display:grid;grid-template-columns:165px 1fr;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid #f4f4f6}
  .gbar .blab{font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .gbar .blab small{display:block;color:var(--muted);font-weight:500;font-size:11px}
  .gset{display:flex;flex-direction:column;gap:3px}
  .grow{display:grid;grid-template-columns:46px 1fr 58px;align-items:center;gap:8px}
  .grow .gk{font-size:9.5px;color:var(--muted);font-weight:700;text-transform:uppercase}
  .gtrack{background:#f0f0f3;border-radius:4px;height:13px;overflow:hidden}.gfill{height:100%;border-radius:4px;transition:width .5s ease}
  .gv{text-align:right;font-family:'Archivo';font-weight:700;font-size:12px}
  .glegend{display:flex;gap:14px;font-size:11px;color:var(--muted);margin-bottom:8px}
  .glegend i{width:10px;height:10px;border-radius:2px;display:inline-block;margin-right:4px;vertical-align:-1px}
  .dash-grid{display:grid;grid-template-columns:1.5fr 1fr;gap:20px;align-items:start}
  .mapgrid{display:grid;grid-template-columns:1.1fr .9fr;gap:24px;align-items:start}
  @media(max-width:980px){.dash-grid,.mapgrid{grid-template-columns:1fr}.kpis{grid-template-columns:repeat(2,1fr)}.g3{grid-template-columns:1fr}}
  .bar-row{display:grid;grid-template-columns:165px 1fr 64px;align-items:center;gap:10px;padding:6px 0}
  .bar-row .blab{font-size:13px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .bar-row .blab small{display:block;color:var(--muted);font-weight:500;font-size:11px}
  .bartrack{background:#f0f0f3;border-radius:5px;height:22px;overflow:hidden}
  .barfill{height:100%;border-radius:5px;transition:width .5s ease}
  .bval{text-align:right;font-family:'Archivo';font-weight:700;font-size:14px}
  .seg{display:flex;height:30px;border-radius:6px;overflow:hidden;border:1px solid var(--line);margin:6px 0 12px}
  .seg span{display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;font-family:'Archivo';min-width:0;overflow:hidden;white-space:nowrap}
  .legend{display:flex;flex-wrap:wrap;gap:12px;font-size:12px;color:var(--muted)}
  .legend i{width:11px;height:11px;border-radius:2px;display:inline-block;margin-right:5px;vertical-align:-1px}
  /* map */
  #mapWrap{position:relative}
  .indiasvg{width:100%;height:auto;display:block;max-height:560px}
  .stp{fill:#e9eaee;stroke:#fff;stroke-width:.6;transition:fill .35s ease;cursor:pointer}
  .stp:hover,.stp.hot{stroke:#2E2E38;stroke-width:1.2}
  .maptip{position:absolute;pointer-events:none;background:var(--charcoal);color:#fff;padding:10px 12px;border-radius:8px;font-size:12px;min-width:172px;opacity:0;transition:opacity .12s;z-index:30;border-left:3px solid var(--ey-yellow);box-shadow:0 10px 30px rgba(0,0,0,.32)}
  .maptip b{font-family:'Archivo'}
  .maptip .trow{display:flex;justify-content:space-between;gap:14px;margin-top:3px}.maptip .trow span{color:#bdbdc8}
  .maptip .tsub{margin-top:6px;padding-top:6px;border-top:1px solid #4a4a57;color:#bdbdc8;font-size:11px}.maptip .tno{color:#bdbdc8;margin-top:4px}
  .legbar{height:12px;border-radius:6px;background:linear-gradient(90deg,#FFF7C2,#FFD400,#9C7A00)}
  .leglab{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:5px}
  .heatwrap{overflow-x:auto}
  .heat{width:100%;border-collapse:collapse;font-size:12px;min-width:680px}
  .heat th{font-family:'Archivo';font-size:10px;text-transform:uppercase;letter-spacing:.02em;color:var(--muted);padding:8px 6px;text-align:center;border-bottom:2px solid var(--line);font-weight:700}
  .heat th.sortable{cursor:pointer;user-select:none}.heat th.sortable:hover{color:var(--charcoal)}
  .heat th.rowh,.heat td.rowh{text-align:left;font-weight:700;color:var(--charcoal);white-space:nowrap}
  .heat td{padding:8px 6px;text-align:center;border-bottom:1px solid #f0f0f3;font-weight:600;font-variant-numeric:tabular-nums}
  .heat tr.totrow td{font-family:'Archivo';font-weight:800;background:#fafafb}
  .heat td.totcol{font-family:'Archivo';font-weight:800;background:#fafafb}
  table.subs{width:100%;border-collapse:collapse;font-size:13px}
  table.subs th{font-family:'Archivo';font-size:11px;text-transform:uppercase;letter-spacing:.03em;color:var(--muted);text-align:left;padding:10px;border-bottom:2px solid var(--line);white-space:nowrap}
  table.subs th.sortable{cursor:pointer;user-select:none}table.subs th.sortable:hover{color:var(--charcoal)}
  table.subs td{padding:10px;border-bottom:1px solid var(--line);vertical-align:top}
  table.subs tr:hover td{background:#fafafb}
  .pill{display:inline-block;font-size:10.5px;font-weight:700;padding:2px 8px;border-radius:20px;background:#f0f0f3;color:var(--charcoal)}
  .pill.H{background:#ffe1e1;color:#b32525}.pill.M{background:#fff2cc;color:#8a6d00}.pill.L{background:#e3f3f0;color:#1f6e64}
  .del{background:none;border:none;color:var(--red);cursor:pointer;font-weight:700;font-size:12px;padding:4px 8px;border-radius:5px}.del:hover{background:#fde8e8}
  .blank{text-align:center;padding:60px 20px;color:var(--muted)}.blank .big{font-family:'Archivo';font-weight:800;font-size:18px;color:var(--charcoal);margin-bottom:6px}
  footer{max-width:1280px;margin:0 auto;padding:0 32px 40px;color:var(--muted);font-size:12px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
</style>
</head>
<body>
<header>
  <div class="head-inner"><div class="brandrow">
    <span class="ey-mark"><span class="beam"></span>EY</span>
    <div class="head-titles"><h1>Skilled Manpower Demand Aggregation</h1>
      <p>FMCG Value Chain &middot; Sub-Sector &amp; Geography-wise Demand Capture</p></div>
    <span class="tag">Demand Aggregation Form</span>
  </div></div>
  <div class="tabbar">
    <button class="tab active" data-tab="form">Submit Demand</button>
    <button class="tab" data-tab="dash">Aggregated Demand <span class="badge" id="countBadge">0</span></button>
  </div>
</header>

<div class="wrap">
  <!-- FORM -->
  <div class="view show" id="view-form">
    <div class="notice">Select a value chain function, identify yourself, then capture demand for each sub-sector across the states/districts you cover. Add as many demand lines as needed — every submission is pooled into the aggregated dashboard.</div>
    <div class="card mb">
      <div class="card-h"><span class="step-no">1</span><h2>Value chain function <span class="req">*</span></h2><span class="sub">Where in the FMCG value chain are you reporting demand from?</span></div>
      <div class="card-b"><div class="vc-pick" id="vcPick"></div></div>
    </div>
    <div class="card mb">
      <div class="card-h"><span class="step-no">2</span><h2>Respondent details</h2><span class="sub">Who is reporting this demand</span></div>
      <div class="card-b">
        <div class="grid g3">
          <div><label>Respondent name <span class="req">*</span></label><input id="f_name" placeholder="e.g. Ramesh Kumar"></div>
          <div><label>Designation / role</label><input id="f_desig" placeholder="e.g. Regional HR Lead"></div>
          <div><label>Organisation / business unit <span class="req">*</span></label><input id="f_org" placeholder="e.g. North Zone Operations"></div>
        </div>
        <div class="grid g3" style="margin-top:16px">
          <div><label>Reporting date</label><input type="date" id="f_date"></div>
          <div><label>Demand origin <span class="req">*</span></label><select id="f_origin"><option value="">Select origin…</option><option value="captive">Captive (In-house)</option><option value="vendor">Extended Ecosystem (Vendor)</option></select></div>
        </div>
      </div>
    </div>
    <div class="card">
      <div class="card-h"><span class="step-no">3</span><h2>Demand by sub-sector &amp; geography</h2><span class="sub" id="demandHint">Select a value chain function above to begin</span></div>
      <div class="card-b">
        <div id="demandWrap" style="display:none">
          <div class="lines"><table>
            <thead><tr>
              <th style="min-width:200px">Sub-sector</th><th style="min-width:150px">State</th><th style="min-width:160px">District / city</th>
              <th>Open now</th><th>+6 months</th><th>+12 months</th><th>Priority</th><th></th>
            </tr></thead><tbody id="lineBody"></tbody>
          </table></div>
          <div style="margin-top:12px"><button class="btn btn-ghost btn-sm" id="btnAddLine">+ Add demand line</button></div>
        </div>
        <div id="demandEmpty" class="empty-d">Pick a value chain function to load its sub-sectors and start capturing demand.</div>
        <div class="actions">
          <button class="btn btn-primary" id="btnSubmit" disabled>Submit demand &rarr;</button>
          <button class="btn btn-ghost" id="btnReset">Clear form</button>
          <span class="hint" id="formHint"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div class="view" id="view-dash">
    <div class="toolbar"><h2>Aggregated demand dashboard</h2>
      <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
        <button class="btn btn-ghost btn-sm" id="btnSeed">↻ Load sample</button>
        <button class="btn btn-ghost btn-sm" id="btnClear" style="color:var(--red)">Clear all</button>
        <span style="width:1px;height:22px;background:var(--line)"></span>
        <button class="btn btn-primary btn-sm" id="btnXlsx">⤓ Export Excel</button>
        <button class="btn btn-ghost btn-sm" id="btnCsv">Export CSV</button>
        <button class="btn btn-dark btn-sm" id="btnJson">Export JSON</button>
      </div>
    </div>
    <div id="dashEmpty" class="card"><div class="blank"><div class="big">No demand submitted yet</div>Totals, a geographic demand map, sub-sector demand and a state × value-chain heatmap appear here once respondents start submitting.<div style="margin-top:18px"><button class="btn btn-primary" id="btnSeedEmpty">↻ Load sample data</button></div></div></div>
    <div id="dashBody" style="display:none">
      <div class="kpis">
        <div class="kpi"><div class="lab">Submissions</div><div class="val" id="kSubs">0</div><div class="sub" id="kLines">0 demand lines</div></div>
        <div class="kpi"><div class="lab">Open positions now</div><div class="val" id="kCur">0</div><div class="sub">vacant today</div></div>
        <div class="kpi"><div class="lab">Demand · +6 months</div><div class="val" id="k6">0</div><div class="sub">projected need</div></div>
        <div class="kpi"><div class="lab">Demand · +12 months</div><div class="val" id="k12">0</div><div class="sub">total skilling target</div></div>
        <div class="kpi"><div class="lab">Demand origin (+12m)</div><div class="val" id="kOriVal" style="font-size:22px">—</div><div class="sub" id="kOriSub"></div></div>
      </div>
      <div class="chips" id="chips"></div>
      <div class="card mb"><div class="card-b" style="padding:16px 20px"><div class="filtbar">
        <div class="fitem"><label>Value chain</label><select id="fl_vc"><option value="">All</option></select></div>
        <div class="fitem" style="max-width:210px"><label>Demand origin</label><select id="fl_origin"><option value="">All</option><option value="captive">Captive (In-house)</option><option value="vendor">Extended Ecosystem (Vendor)</option></select></div>
        <div class="fitem"><label>State / UT</label><select id="fl_state"><option value="">All</option></select></div>
        <div class="fitem"><label>Sub-sector</label><select id="fl_sub"><option value="">All</option></select></div>
        <div class="fitem" style="max-width:160px"><label>Priority</label><select id="fl_pri"><option value="">All</option><option value="H">High</option><option value="M">Medium</option><option value="L">Low</option><option value="_">Unspecified</option></select></div>
        <button class="btn btn-ghost btn-sm" id="btnClearF" style="align-self:end">Clear filters</button>
      </div><div class="hint" id="filtInfo" style="margin-top:10px"></div></div></div>
      <div class="metricbar"><span style="font-family:'Archivo';font-weight:700;font-size:13px">Time horizon:</span>
        <div class="metric-toggle" id="metricToggle">
          <button data-m="current">Open now</button><button data-m="m6">+6 months</button><button data-m="m12" class="on">+12 months</button><button data-m="all">All (whole)</button>
        </div>
      </div>

      <div class="card mb">
