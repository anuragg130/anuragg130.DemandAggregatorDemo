  const leg=`<div class="glegend">${MET.map(m=>`<span><i style="background:${m.col}"></i>${m.l}</span>`).join("")}</div>`;
  container.innerHTML=leg+(entries.map(([k,v])=>`<div class="gbar"><div class="blab" title="${escA(k)}">${esc(k)}${subFn?`<small>${esc(subFn(k))}</small>`:""}</div>
    <div class="gset">${MET.map(m=>`<div class="grow"><span class="gk">${m.l}</span><div class="gtrack"><div class="gfill" style="width:${v[m.k]/max*100}%;background:${m.col}"></div></div><div class="gv">${fmt(v[m.k])}</div></div>`).join("")}</div></div>`).join("")||`<div class="hint">No data for the current filters.</div>`);}
function applyFilters(rows){return rows.filter(r=>(!FILT.vc||r.valueChain===FILT.vc)&&(!FILT.state||r.state===FILT.state)&&(!FILT.sub||r.subSector===FILT.sub)&&(!FILT.pri||(r.priority||"_")===FILT.pri)&&(!FILT.origin||(r.source||"_")===FILT.origin));}
