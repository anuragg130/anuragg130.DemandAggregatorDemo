function aggBy(rows,key){const m={};rows.forEach(r=>{const k=key(r);m[k]=(m[k]||0)+(r[AMETRIC]||0);});return m;}
function bars(container,entries,colorFn,subFn){const max=Math.max(...entries.map(e=>e[1]),1);
  container.innerHTML=entries.map(([k,v])=>`<div class="bar-row"><div class="blab" title="${escA(k)}">${esc(k)}${subFn?`<small>${esc(subFn(k))}</small>`:""}</div>
