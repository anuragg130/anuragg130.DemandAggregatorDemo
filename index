/* ----- heatmap (sortable) ----- */
function renderHeat(rows){
  const cell={},stTot={},vcTot={};let grand=0,maxCell=0;
  const stateList=[...new Set(rows.map(r=>r.state))];
  rows.forEach(r=>{cell[r.state+"||"+r.valueChain]=(cell[r.state+"||"+r.valueChain]||0)+(r[AMETRIC]||0);});
  stateList.forEach(st=>{stTot[st]=0;VC_KEYS.forEach(vc=>{const v=cell[st+"||"+vc]||0;stTot[st]+=v;vcTot[vc]=(vcTot[vc]||0)+v;grand+=v;if(v>maxCell)maxCell=v;});});
  const kv=st=>heatSort.key==="State"?st:heatSort.key==="Total"?stTot[st]:(cell[st+"||"+heatSort.key]||0);
  stateList.sort((a,b)=>{const va=kv(a),vb=kv(b);if(heatSort.key==="State")return(va<vb?-1:va>vb?1:0)*heatSort.dir;return(va-vb)*heatSort.dir;});
  const arrow=k=>heatSort.key===k?(heatSort.dir>0?" ▲":" ▼"):"";
  const col=v=>{if(!v)return "background:transparent;color:#c4c4cc";const a=0.14+0.82*(v/(maxCell||1));return `background:rgba(255,214,0,${a.toFixed(2)});color:${a>0.62?'#5a4f00':'#1b1b21'}`;};
  let h=`<thead><tr><th class="rowh sortable" data-hk="State">State / UT${arrow("State")}</th>`+
    VC_KEYS.map(vc=>`<th class="sortable" data-hk="${escA(vc)}" title="${escA(vc)}">${esc(VC_SHORT[vc])}${arrow(vc)}</th>`).join("")+
    `<th class="sortable" data-hk="Total">Total${arrow("Total")}</th></tr></thead><tbody>`;
  stateList.forEach(st=>{h+=`<tr><td class="rowh">${esc(st)}</td>`+VC_KEYS.map(vc=>{const v=cell[st+"||"+vc]||0;return `<td style="${col(v)}">${v?fmt(v):'–'}</td>`;}).join("")+`<td class="totcol">${fmt(stTot[st])}</td></tr>`;});
  h+=`<tr class="totrow"><td class="rowh">Total</td>`+VC_KEYS.map(vc=>`<td>${vcTot[vc]?fmt(vcTot[vc]):'–'}</td>`).join("")+`<td>${fmt(grand)}</td></tr></tbody>`;
  $("#heat").innerHTML=h;
  $$("#heat th.sortable").forEach(th=>th.onclick=()=>{const k=th.dataset.hk;if(heatSort.key===k)heatSort.dir*=-1;else{heatSort.key=k;heatSort.dir=k==="State"?1:-1;}renderHeat(flatten());});
}

/* ----- submission log (sortable, flat) ----- */
const LOGCOLS=[{k:"name",l:"Respondent",t:"s"},{k:"org",l:"Organisation",t:"s"},{k:"date",l:"Date",t:"s"},
  {k:"valueChain",l:"Value chain",t:"s"},{k:"source",l:"Origin",t:"s"},{k:"subSector",l:"Sub-sector",t:"s"},
