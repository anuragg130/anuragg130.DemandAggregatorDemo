    const cur=+(tr.querySelector(".d-cur").value||0),m6=+(tr.querySelector(".d-m6").value||0),m12=+(tr.querySelector(".d-m12").value||0);
    const pri=tr.querySelector(".d-pri").value;
    if(ss&&state&&(cur||m6||m12))out.push({subSector:ss,state,district:dist,current:cur,m6,m12,priority:pri});});return out;}
