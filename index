const PREFIX="demand_sub:";const mem={};
const hasWS=(typeof window!=="undefined"&&typeof window.storage!=="undefined");
let lsOK=false; if(!hasWS){try{const t="__t";localStorage.setItem(t,"1");localStorage.removeItem(t);lsOK=true;}catch(e){lsOK=false;}}
async function storeSet(id,o){const v=JSON.stringify(o);if(hasWS){try{await window.storage.set(PREFIX+id,v,true);return;}catch(e){}}if(lsOK){try{localStorage.setItem(PREFIX+id,v);return;}catch(e){}}mem[id]=o;}
async function storeDelete(id){if(hasWS){try{await window.storage.delete(PREFIX+id,true);return;}catch(e){}}if(lsOK){try{localStorage.removeItem(PREFIX+id);return;}catch(e){}}delete mem[id];}
async function storeAll(){const out=[];
  if(hasWS){try{const r=await window.storage.list(PREFIX,true);const ks=(r&&r.keys)?r.keys:[];for(const k of ks){try{const g=await window.storage.get(k,true);if(g&&g.value)out.push(JSON.parse(g.value));}catch(e){}}return out.sort((a,b)=>b.ts-a.ts);}catch(e){}}
  if(lsOK){try{for(let i=0;i<localStorage.length;i++){const k=localStorage.key(i);if(k&&k.startsWith(PREFIX)){try{out.push(JSON.parse(localStorage.getItem(k)));}catch(e){}}}return out.sort((a,b)=>b.ts-a.ts);}catch(e){}}
  return Object.values(mem).sort((a,b)=>b.ts-a.ts);}

