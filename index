function ssOptions(){const s=VALUE_CHAIN[selectedVC]||[];return `<option value="">Select sub-sector…</option>`+s.map(x=>`<option value="${escA(x)}">${esc(x)}</option>`).join("")+`<option value="__other">Other…</option>`;}
function stateOptions(){return `<option value="">Select state…</option>`+STATES.map(x=>`<option value="${escA(x)}">${esc(x)}</option>`).join("");}
function distOptions(st){const d=INDIA.districts[st]||[];return `<option value="">Select district…</option>`+d.map(x=>`<option value="${escA(x)}">${esc(x)}</option>`).join("")+`<option value="__other">Other…</option>`;}
function priOptions(){return `<option value="">—</option><option value="H">High</option><option value="M" selected>Medium</option><option value="L">Low</option>`;}
function selectVC(vc){selectedVC=vc;$$(".vc-btn").forEach(b=>b.classList.toggle("sel",b.dataset.vc===vc));
