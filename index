      const key=ss+"|"+st+"|"+dist;if(used[key])continue;used[key]=1;
      const cur=ri(0,30),m6=cur+ri(5,55),m12=m6+ri(10,95);
      lines.push({subSector:ss,state:st,district:dist,current:cur,m6,m12,priority:rnd(["H","M","L","M","L","H"])});
    }
    if(!lines.length)continue;
    const sub={id:Date.now().toString(36)+i+Math.random().toString(36).slice(2,6),ts:Date.now()-ri(0,500000),name:rnd(NAMES),desig:rnd(DESIG),org:rnd(ORGS),date,valueChain:vc,source,lines};
    await storeSet(sub.id,sub);
  }
  DATA=await storeAll();$("#countBadge").textContent=DATA.length;populateFilters();
  $("#dashEmpty").style.display="none";$("#dashBody").style.display="block";renderAll();
  toast("Loaded "+n+" sample submissions");
}
async function clearAll(){if(!confirm("Delete ALL demand data (including sample data)? This cannot be undone."))return;
  const all=await storeAll();for(const s of all)await storeDelete(s.id);
  DATA=[];FILT={vc:"",state:"",sub:"",pri:"",origin:""};$("#countBadge").textContent=0;loadDash();toast("All data cleared");}
</script>
