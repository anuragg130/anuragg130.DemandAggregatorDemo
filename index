function agg3(rows,kf){const m={};rows.forEach(r=>{const k=kf(r);(m[k]=m[k]||{c:0,a:0,b:0}),m[k].c+=r.current,m[k].a+=r.m6,m[k].b+=r.m12;});return m;}
const MET=[{k:"c",l:"Open now",col:"#b3b8c0"},{k:"a",l:"+6m",col:"#FFD400"},{k:"b",l:"+12m",col:"#2E2E38"}];
